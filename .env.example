# YouTube AI Agent — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# OR run: node scripts/setup.js (interactive wizard)
#
# Variables marked [REQUIRED] must be set for the agent to run.
# Variables marked [OPTIONAL] can be left blank — the feature will be skipped.

# ── [REQUIRED] YouTube Data API v3 ───────────────────────────────────────────
# Get from: console.cloud.google.com → Enable "YouTube Data API v3" → Credentials → API Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── [REQUIRED] Google Gemini AI ──────────────────────────────────────────────
# Get from: aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── [REQUIRED] Gmail Email Delivery ──────────────────────────────────────────
# GMAIL_USER: The Gmail address used to SEND daily digest emails
# GMAIL_PASS: Gmail App Password (NOT your login password)
#   Setup: myaccount.google.com/apppasswords → Create → copy 16-char password
# RECIPIENT_EMAIL: Where to RECEIVE the daily digest (can be same as GMAIL_USER)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_gmail_app_password_here
RECIPIENT_EMAIL=recipient_email@gmail.com

# ── [REQUIRED] Channel Branding ──────────────────────────────────────────────
# Your YouTube channel / brand name — appears on thumbnails and in script CTAs
CHANNEL_NAME=YourChannelName

# ── [OPTIONAL] Notion Content Calendar ───────────────────────────────────────
# Creates a daily content brief page in your Notion database.
# Leave blank to skip Notion integration gracefully.
# Setup:
#   1. notion.so/profile/integrations → New internal integration → copy token
#   2. Open your Notion database → share URL → copy 32-char database ID
#   3. Connect integration: open DB page → ··· → Connections → add integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── [OPTIONAL] Discord Notifications ─────────────────────────────────────────
# Sends a rich embed to your Discord channel when the pipeline runs.
# Leave blank to skip Discord notifications gracefully.
# Setup: Discord → your server → channel settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ── [OPTIONAL] YouTube Auto-Upload OAuth 2.0 ─────────────────────────────────
# Automatically uploads the daily generated video to your YouTube channel.
# Leave blank to skip auto-upload (video is still generated locally / in email).
# Setup:
#   1. console.cloud.google.com → Credentials → Create OAuth 2.0 Client ID → Desktop App
#   2. Add YOUTUBE_OAUTH_CLIENT_ID and YOUTUBE_OAUTH_CLIENT_SECRET below
#   3. Run: node scripts/auth_youtube.js  (one-time browser login)
#   4. Paste the refresh token from the terminal output below
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
