# ════════════════════════════════════════════════════════════
#   YouTube AI Content Automation Agent — Environment Config
#   Copy this file to .env and fill in your values
#   Instructions: See README.md
# ════════════════════════════════════════════════════════════

# ── Your Channel Identity ─────────────────────────────────────────────────────
# This name appears on thumbnails, in scripts, and in Discord notifications
CHANNEL_NAME=MyChannel

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from: console.cloud.google.com → Enable "YouTube Data API v3" → Create API Key
YOUTUBE_API_KEY=

# ── Gmail (for daily email reports) ───────────────────────────────────────────
# Use an App Password, NOT your regular Gmail password
# Enable: myaccount.google.com/security → 2FA → App Passwords → Mail
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Email where you want to receive daily reports
RECIPIENT_EMAIL=your_email@gmail.com

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get from: aistudio.google.com/app/apikey (free tier available)
GEMINI_API_KEY=

# ── Notion Integration (OPTIONAL) ────────────────────────────────────────────
# Leave blank to skip — pipeline will run without Notion
# Setup: notion.so/my-integrations → New Integration (Internal) → Copy Token
# Then: Share your Notion database with the integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Discord Notifications (OPTIONAL) ─────────────────────────────────────────
# Leave blank to skip — pipeline will run without Discord
# Setup: Your Discord Server → Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── YouTube OAuth 2.0 (for auto-upload) ──────────────────────────────────────
# REQUIRED for auto-upload to your YouTube channel
# Step 1: console.cloud.google.com → Credentials → Create OAuth 2.0 Client ID → Desktop App
# Step 2: Add YOUTUBE_OAUTH_CLIENT_ID and YOUTUBE_OAUTH_CLIENT_SECRET below
# Step 3: Run: node scripts/auth_youtube.js  (one-time browser login)
# Step 4: Paste the refresh token printed by the script below
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
