# YouTube Data API v3 Key
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gmail credentials
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_gmail_app_password_here

# Email recipient
RECIPIENT_EMAIL=recipient_email@gmail.com

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Phase 2D: Notion Integration (optional) ───────────────────────────────────
# Leave blank to skip Notion integration gracefully
# Setup guide: https://developers.notion.com/docs/getting-started
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Phase 2E: Discord Webhook Notification (optional) ────────────────────────
# Leave blank to skip Discord notification gracefully
# Create a webhook: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
# Phase 3A: Google Cloud Text-to-Speech (for AI voiceover)
# Get from: console.cloud.google.com → APIs & Services → Credentials → API Key
# Enable: Cloud Text-to-Speech API
GOOGLE_TTS_API_KEY=your_google_cloud_tts_api_key

# Phase 3B: YouTube OAuth 2.0 (for auto-upload to your channel)
# Step 1: console.cloud.google.com → Credentials → OAuth 2.0 Client ID → Desktop App
# Step 2: Run `node scripts/auth_youtube.js` to get the refresh token
YOUTUBE_OAUTH_CLIENT_ID=your_oauth_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_OAUTH_REFRESH_TOKEN=your_refresh_token_from_auth_script
